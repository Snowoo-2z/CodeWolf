            {"id":"css.responsive","title":"Responsive design","category":"CSS","difficulty":3,"prerequisites":["css.flexbox"],"objectives":["Utiliser les media queries","Concevoir mobile-first"],"evidence":["@media","clamp","viewport"]},
            {"id":"js.functions","title":"Fonctions et portée","category":"JavaScript","difficulty":3,"prerequisites":["js.basics"],"objectives":["Décomposer un problème","Comprendre paramètres et retour"],"evidence":["function","return","scope"]},
            {"id":"js.dom","title":"Manipulation du DOM","category":"JavaScript","difficulty":3,"prerequisites":["js.functions","html.semantic"],"objectives":["Sélectionner un élément","Modifier l’interface"],"evidence":["querySelector","textContent","classList"]},
            {"id":"js.events","title":"Événements utilisateur","category":"JavaScript","difficulty":3,"prerequisites":["js.dom"],"objectives":["Écouter une interaction","Mettre à jour l’état visuel"],"evidence":["addEventListener","click","input"]},
            {"id":"a11y.basics","title":"Accessibilité fondamentale","category":"Qualité","difficulty":3,"prerequisites":["html.semantic","html.forms"],"objectives":["Naviguer au clavier","Fournir des noms accessibles"],"evidence":["alt","aria","focus","label"]}
          ]
        },
        {
          "id": "advanced",
