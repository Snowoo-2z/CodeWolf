            {"id":"js.basics","title":"Variables, types et conditions","category":"JavaScript","difficulty":2,"prerequisites":["html.document"],"objectives":["Déclarer une donnée","Écrire une condition"],"evidence":["const","let","if","boolean"]}
          ]
        },
        {
