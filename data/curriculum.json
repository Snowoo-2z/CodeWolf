            {"id":"css.box-model","title":"Box model et espacements","category":"CSS","difficulty":1,"prerequisites":["css.selectors"],"objectives":["Distinguer margin et padding","Dimensionner un composant"],"evidence":["padding","margin","border","box-sizing"]},
