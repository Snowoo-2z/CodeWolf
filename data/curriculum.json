            {"id":"js.async","title":"JavaScript asynchrone","category":"JavaScript","difficulty":4,"prerequisites":["js.functions"],"objectives":["Consommer une promesse","Gérer les erreurs réseau"],"evidence":["async","await","try","catch"]},
            {"id":"web.api","title":"Consommer une API","category":"JavaScript","difficulty":4,"prerequisites":["js.async"],"objectives":["Effectuer une requête","Afficher les données et erreurs"],"evidence":["fetch","response","json"]},
            {"id":"quality.testing","title":"Tests et débogage","category":"Qualité","difficulty":4,"prerequisites":["js.events"],"objectives":["Définir un cas de test","Diagnostiquer une régression"],"evidence":["assert","console","edge case"]},
            {"id":"project.architecture","title":"Architecture d’un projet","category":"Qualité","difficulty":5,"prerequisites":["js.dom","css.responsive"],"objectives":["Séparer les responsabilités","Organiser des modules"],"evidence":["module","import","separation of concerns"]}
